{
  "name": "desktop",
  "version": "0.36.0",
  "description": "lamda Electron desktop app",
  "main": "dist/main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "npm run build:app && electron .",
    "dev": "electron bootstrap.mjs",
    "build:app": "node build.mjs --bundle-only",
    "build": "node build.mjs",
    "lint": "eslint src",
    "check-types": "tsc --project tsconfig.json --noEmit"
  },
  "keywords": [],
  "author": "Snehasish Dawn",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@lamda/server": "*",
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "electron": "42.4.1",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "tsx": "4.21.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "build": {
    "appId": "com.sdawn29.lamda",
    "productName": "lamda",
    "electronVersion": "42.4.1",
    "directories": {
      "output": "release"
    },
    "compression": "maximum",
    "asar": true,
    "files": [
      "dist/**/*"
    ],
    "extraResources": [
      {
        "from": "../web/dist",
        "to": "web",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../server/dist",
        "to": "server",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "assets/splash.html",
        "to": "splash.html"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "sdawn29",
      "repo": "lamda"
    },
    "afterSign": "notarize.mjs",
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.developer-tools",
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.inherit.plist",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ]
    }
  }
}
