{
  "name": "desktop",
  "version": "0.0.2",
  "description": "lamda Electron desktop app",
  "main": "dist/main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "npm run build:app && electron .",
    "dev": "electron bootstrap.mjs",
    "build:app": "node build.mjs --bundle-only",
    "build": "node build.mjs",
    "lint": "eslint src",
    "check-types": "tsc --project tsconfig.json --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@lamda/server": "*"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "electron": "41.1.1",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0"
  },
  "build": {
    "appId": "com.sdawn29.lamda",
    "productName": "lamda",
    "electronVersion": "41.1.1",
    "directories": {
      "output": "release"
    },
    "compression": "maximum",
    "asar": true,
    "files": [
      "dist/**/*"
    ],
    "extraResources": [
      {
        "from": "../web/dist",
        "to": "web",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../server/dist",
        "to": "server",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.developer-tools",
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ]
    }
  }
}
