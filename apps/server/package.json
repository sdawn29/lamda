{
  "name": "@lamda/server",
  "version": "0.36.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.cjs",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "node build.mjs",
    "start": "node dist/server.cjs",
    "check-types": "tsc --noEmit",
    "postinstall": "node -e \"const{existsSync,chmodSync}=require('fs'),p=require.resolve('node-pty/prebuilds/darwin-arm64/spawn-helper');if(existsSync(p))chmodSync(p,'755');\""
  },
  "dependencies": {
    "@hono/node-server": "^2.0.5",
    "@lamda/db": "*",
    "@lamda/git": "*",
    "@lamda/github": "*",
    "@lamda/gitlab": "*",
    "@lamda/lsp": "*",
    "@lamda/mcp": "*",
    "@lamda/pi-sdk": "*",
    "@types/ws": "^8.18.1",
    "croner": "^10.0.1",
    "hono": "^4.12.26",
    "node-pty": "^1.1.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "esbuild": "^0.28.1",
    "tsx": "4.21.0",
    "typescript": "~6.0.3"
  }
}
