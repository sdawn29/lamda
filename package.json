{
  "name": "lamda",
  "version": "0.33.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "release": "node scripts/release.mjs && npm run build",
    "release:dry-run": "node scripts/release.mjs --dry-run"
  },
  "devDependencies": {
    "prettier": "^3.8.4",
    "turbo": "^2.9.18",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.17.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true,
    "electron-winstaller@5.4.0": true,
    "esbuild@0.28.1": true,
    "esbuild@0.27.7": true,
    "node-pty@1.1.0": true,
    "protobufjs@7.6.4": true,
    "@google/genai@1.52.0": true
  }
}